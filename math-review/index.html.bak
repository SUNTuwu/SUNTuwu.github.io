*{margin:0;padding:0;box-sizing:border-box}
body{font-family:-apple-system,BlinkMacSystemFont,'Segoe UI',Roboto,sans-serif;background:#0d1117;color:#e6edf3;display:flex;min-height:100vh}
::selection{background:#1f6feb44}
.sidebar{width:280px;min-width:280px;background:#161b22;border-right:1px solid #30363d;padding:24px 0;height:100vh;position:sticky;top:0;overflow-y:auto}
.sidebar h1{font-size:16px;padding:0 20px 16px;color:#f0f6fc;border-bottom:1px solid #30363d;margin-bottom:12px}
.sidebar h1 small{display:block;font-size:12px;color:#8b949e;font-weight:normal;margin-top:4px}
.module-nav{padding:4px 12px;cursor:pointer;border-radius:6px;margin:2px 8px;font-size:13px;color:#c9d1d9;display:block;text-decoration:none;transition:all .15s}
.module-nav:hover{background:#1f6feb22;color:#f0f6fc}
.module-nav.active{background:#1f6feb33;color:#58a6ff;font-weight:600}
.module-nav .count{float:right;background:#21262d;padding:0 8px;border-radius:10px;font-size:11px;color:#8b949e}
.sidebar .outline-link{display:block;padding:12px 20px 4px;font-size:12px;color:#8b949e;text-decoration:none}
.sidebar .outline-link:hover{color:#58a6ff}
.content{flex:1;padding:32px 48px;max-width:960px}
.module-section{display:none}
.module-section.active{display:block}
.module-header{margin-bottom:24px;padding-bottom:16px;border-bottom:2px solid #21262d}
.module-header h2{font-size:24px;color:#f0f6fc}
.module-header .lectures{font-size:13px;color:#8b949e;margin-top:4px}
.module-header .outline-link{display:inline-block;margin-top:8px;font-size:12px;color:#58a6ff;text-decoration:none}
.module-header .outline-link:hover{text-decoration:underline}
.module-subtitle{font-size:14px;color:#8b949e;margin:8px 0 16px}
.exercise{background:#161b22;border:1px solid #30363d;border-radius:8px;margin-bottom:16px;overflow:hidden}
.exercise-header{display:flex;align-items:center;justify-content:space-between;padding:12px 16px;background:#1c2128;border-bottom:1px solid #30363d;flex-wrap:wrap;gap:8px}
.exercise-id{font-weight:600;font-size:14px;color:#f0f6fc}
.exercise-lecture{font-size:12px;color:#8b949e}
.exercise-tags{display:flex;gap:6px;flex-wrap:wrap}
.tag{font-size:11px;padding:2px 8px;border-radius:12px;background:#1f6feb22;color:#58a6ff;border:1px solid #1f6feb44;text-decoration:none;transition:all .15s}
.tag:hover{background:#1f6feb44}
.exercise-body{padding:16px}
.exercise-problem{font-size:15px;line-height:1.7;margin-bottom:12px}
.exercise-similar{font-size:12px;color:#8b949e;padding:8px 12px;background:#0d1117;border-radius:6px;margin-bottom:12px}
.codebox{display:flex;align-items:stretch;background:#0d1117;border:1px solid #30363d;border-radius:6px;font-family:'JetBrains Mono','Fira Code',monospace;font-size:13px}
.codebox pre{flex:1;padding:10px 14px;margin:0;overflow-x:auto;color:#e6edf3;white-space:pre-wrap}
.codebox button{flex-shrink:0;padding:8px 14px;background:#21262d;border:none;border-left:1px solid #30363d;color:#c9d1d9;cursor:pointer;font-size:12px;transition:all .15s;border-radius:0 6px 6px 0}
.codebox button:hover{background:#30363d;color:#f0f6fc}
.codebox button.copied{background:#238636;color:#fff}
.summary-section{background:#161b22;border:1px solid #30363d;border-radius:8px;padding:20px;margin-bottom:24px}
.summary-section h3{font-size:16px;color:#f0f6fc;margin-bottom:12px}
.stat-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(120px,1fr));gap:12px}
.stat-card{text-align:center;padding:12px;background:#0d1117;border-radius:8px}
.stat-card .num{font-size:24px;font-weight:700;color:#58a6ff}
.stat-card .label{font-size:11px;color:#8b949e;margin-top:4px}
::-webkit-scrollbar{width:8px}
::-webkit-scrollbar-track{background:#0d1117}
::-webkit-scrollbar-thumb{background:#30363d;border-radius:4px}
::-webkit-scrollbar-thumb:hover{background:#484f58}
@media(max-width:768px){.sidebar{display:none}.content{padding:16px}}
</style>
</head>
