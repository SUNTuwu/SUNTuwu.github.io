<div class="exercise">
<div class="exercise-header">
<div><span class="exercise-id">Exercise L22-3</span> <span class="exercise-lecture">(Lecture 22)</span></div>
<div class="exercise-tags"><a class="tag" href="../study_outline.md#module-8-power-series-taylor-series-applications" target="_blank">taylor-inequality</a> <a class="tag" href="../study_outline.md#module-8-power-series-taylor-series-applications" target="_blank">error-estimation</a></div>
</div>
<div class="exercise-body">
<div class="exercise-problem">Use Taylor's Inequality to determine the number of terms of the Maclaurin series for $ e^{x} $ needed to estimate $ e^{0.1} $ to within 0.00001.</div>
<div class="exercise-similar">📌 Similar examples: Lecture 22 Example: approximate ³√x by Taylor polynomial at a=8; error bounds for sin x</div>
<div class="codebox">
<pre id="latex-L22-3">e^{0.1},\quad \text{accuracy } 0.00001</pre>
<button onclick="copyLaTeX('L22-3')" id="btn-L22-3">Copy LaTeX</button>
</div>
</div></div>
</div>
</div>

<script>
function showModule(id) {
    document.querySelectorAll('.module-section').forEach(function(el){el.classList.remove('active')});
    document.getElementById('module-' + id).classList.add('active');
    document.querySelectorAll('.module-nav').forEach(function(el){el.classList.remove('active')});
    var nav = document.querySelector('.module-nav[data-module="'+id+'"]');
    if (nav) nav.classList.add('active');
    if (window.MathJax && MathJax.typesetPromise) {
        MathJax.typesetPromise([document.getElementById('module-' + id)]);
    }
}
function copyLaTeX(id) {
    var pre = document.getElementById('latex-' + id);
    var btn = document.getElementById('btn-' + id);
    if (!pre || !btn) return;
    navigator.clipboard.writeText(pre.textContent).then(function() {
        btn.textContent = 'Copied!';
        btn.classList.add('copied');
        setTimeout(function(){btn.textContent='Copy LaTeX';btn.classList.remove('copied')}, 2000);
    });
}
</script>
</body>
</html>